{
  "name": "@myfarms/mf-select",
  "version": "1.7.5",
  "scripts": {
    "build": "ng-packagr -p ng-package.json",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --runInBand",
    "lite": "lite-server",
    "playground:build": "webpack --config playground/webpack.config.js --watch",
    "playground": "concurrently --kill-others \"npm run playground:build\" \"npm run lite\""
  },
  "jest": {
    "preset": "jest-preset-angular",
    "setupFilesAfterEnv": [
      "<rootDir>/src/jest.ts"
    ],
    "transform": {
      "^.+\\.(ts|mjs|js|html)$": [
        "jest-preset-angular",
        {
          "tsconfig": "<rootDir>/tsconfig.spec.json",
          "stringifyContentPathRegex": "\\.(html|svg)$"
        }
      ]
    },
    "modulePathIgnorePatterns": [
      "<rootDir>/src/package.json",
      "<rootDir>/dist/"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/myfarms/mf-select"
  },
  "author": {
    "name": "MyFarms",
    "email": "administrator@myfarms.com"
  },
  "contributors": [
    {
      "name": "Adam Keenan",
      "email": "adam.g.keenan@gmail.com"
    },
    {
      "name": "Simon Smith",
      "email": "simon.smith@myfarms.com"
    },
    {
      "name": "Dylan Hamilton",
      "email": "dylan.hamilton@myfarms.com"
    }
  ],
  "keywords": [
    "angular"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/myfarms/mf-select/issues"
  },
  "peerDependencies": {
    "@angular/common": "^20.0.0",
    "@angular/core": "^20.0.0",
    "@angular/cdk": "^20.0.0",
    "rxjs": "^7.8.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/cdk": "^20.0.0",
    "@angular/common": "20.3.25",
    "@angular/compiler": "20.3.25",
    "@angular/compiler-cli": "20.3.25",
    "@angular/core": "20.3.25",
    "@angular/forms": "20.3.25",
    "@angular/platform-browser": "20.3.25",
    "@angular/platform-browser-dynamic": "20.3.25",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^29.0.0",
    "jest-preset-angular": "^14.0.0",
    "css-loader": "^6.0.0",
    "concurrently": "^8.0.0",
    "lite-server": "^2.6.1",
    "ng-packagr": "^20.0.0",
    "ts-loader": "^9.0.0",
    "webpack": "^5.0.0",
    "webpack-cli": "^5.0.0",
    "rxjs": "^7.8.0",
    "sass": "~1.77.0",
    "sass-loader": "^13.0.0",
    "style-loader": "^3.0.0",
    "typescript": "~5.8.0",
    "zone.js": "~0.15.0"
  },
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=24.0.0"
  }
}
